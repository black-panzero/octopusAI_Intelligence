# backend/.env
# SmartBuy Backend Environment Configuration
# Copy this file to .env and adjust values as needed

# Application Settings
APP_NAME="SmartBuy Deal Aggregation Engine"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL="INFO"

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./smartbuy.db

# API Configuration
API_V1_STR="/api/v1"
DOCS_URL="/docs"
REDOC_URL="/redoc"

# CORS Settings (for future frontend integration)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,https://shiny-giggle-7vvjp5gv747xcrjww-3000.app.github.dev

# Pagination Settings
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
# backend/.env
# SmartBuy Backend Environment Configuration
# Copy this file to .env and adjust values as needed

# Application Settings
APP_NAME="SmartBuy Deal Aggregation Engine"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL="INFO"

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./smartbuy.db

# API Configuration
API_V1_STR="/api/v1"
DOCS_URL="/docs"
REDOC_URL="/redoc"

# CORS Settings — localhost always allowed; *.app.github.dev matched via regex
# in app/main.py so every Codespace works without editing this file.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auth / JWT
# IMPORTANT: override SECRET_KEY with a long random string in production.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
# SECRET_KEY=change-me
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM — AI shopping assistant (any OpenAI-compatible provider)
# Groq is the fastest free option. Sign up at https://console.groq.com and
# paste your key below.
LLM_PROVIDER=groq
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
# Uncomment for OpenRouter instead:
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-...
# LLM_MODEL=openai/gpt-4o-mini
# Optional override for self-hosted / proxied endpoints:
# LLM_BASE_URL=

# Pagination Settings
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100